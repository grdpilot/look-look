{
  "version": "2026.02.28",
  "description": "TVBox绿色过滤基础词库",
  "rules": {
    "hard_filter": {
      "label": "高危核心词",
      "action": "block_resource",
      "keywords": [
        "色情", "淫秽", "成人网", "成人片", "A片", "伦理","AV女优", "久久热", "国产精品", 
        "自拍偷拍", "中出", "颜射", "口爆", "喷潮", "乱伦", "强奸", "迷奸", 
        "制服诱惑", "自慰", "肉欲", "色诱", "一区二区", "三级片", "情色电影"
      ]
    },
    "studio_filter": {
      "label": "违规厂牌/平台",
      "action": "block_resource",
      "keywords": [
        "麻豆传媒", "糖心Vlog", "九一大神", "91传媒", "天美传媒", "果冻传媒", 
        "星空传媒", "蜜桃影像", "一本道", "加勒比", "东京热", "TokyoHot", 
        "S1", "MOODYZ", "PRESTIGE", "IdeaPocket", "SWAG"
      ]
    },
    "tag_filter": {
      "label": "擦边引导标签",
      "action": "filter_display",
      "keywords": [
        "无码", "步兵", "露点", "巨乳", "嫩模", "外围", "夜店", "福利视频", 
        "禁片", "完整版未删减", "深夜视频", "激情影院", "约炮", "看片群"
      ]
    },
    "ad_spam": {
      "label": "非法引流与博彩",
      "action": "block_resource",
      "keywords": [
        "澳门首家", "威尼斯人", "太阳城", "百家乐", "时时彩", "永久域名", 
        "最新网址", "加群看片", "备用地址", "博彩论坛"
      ]
    },
    "regex_patterns": {
      "label": "正则模式识别",
      "patterns": [
        "^[a-zA-Z]{2,6}-?\\d{3,6}$",
        "(微|威|Vx|扣|Q|群)[:：]?\\s*\\d{5,11}",
        "([a-zA-Z0-9][-a-zA-Z0-9]{0,62}(\\.[a-zA-Z0-9][-a-zA-Z0-9]{0,62})+\\.?)"
      ],
      "description": "依次匹配：标准番号格式、社交账号引流、非法网址链接"
    }
  },
  "white_list": {
    "label": "白名单（防误伤）",
    "keywords": [
      "性别", "性能", "色彩", "角色", "色盲", "动物世界", "医学科普", "生理卫生"
    ]
  }
}
